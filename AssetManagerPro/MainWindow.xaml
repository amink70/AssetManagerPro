<Window x:Class="AssetManagerPro.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:views="clr-namespace:AssetManagerPro.Views"
        Title="AssetManager Pro"
        Height="720"
        Width="1280"
        WindowStartupLocation="CenterScreen"
        FlowDirection="RightToLeft"
        Background="#F3F4F6">

    <Grid>

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="260"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- منوی سمت راست -->

        <Border Grid.Column="0"
                Background="#1E293B">

            <DockPanel>

                <TextBlock DockPanel.Dock="Top"
                           Margin="20"
                           FontSize="24"
                           FontWeight="Bold"
                           Foreground="White"
                           Style="{StaticResource TitleText}"
                           Text="سیستم مدیریت اموال"/>

                <StackPanel Margin="15">

                    <Button Style="{StaticResource ModernButton}"  Content="🏠 داشبورد"/>
                    <Button Height="45" Margin="0,5" Content="📦 مدیریت اموال" x:Name="btnAssets"
Click="btnAssets_Click"/>
                    <Button x:Name="btnBrands"
        Height="45"
        Margin="0,5"
        Content="🏷 برندها"
        Click="btnBrands_Click"/>

                    <Button x:Name="btnCategories"
        Height="45"
        Margin="0,5"
        Content="🗂 دسته‌بندی‌ها"
        Click="btnCategories_Click"/>
                    <Button x:Name="btnSuppliers"
        Height="45"
        Margin="0,5"
        Content="🏢 تأمین‌کنندگان"
        Click="btnSuppliers_Click"/>
                    <Button x:Name="btnLocations"
        Height="45"
        Margin="0,5"
        Content="📍 مکان‌ها"
        Click="btnLocations_Click"/>
                    <Button x:Name="btnReceivers"
        Height="45"
        Margin="0,5"
        Content="👥 گیرندگان"
        Click="btnReceivers_Click"/>
                    <Button Height="45" Margin="0,5" Content="👤 کاربران"/>
                    <Button Height="45" Margin="0,5" Content="📊 گزارش‌ها"/>
                    <Button Height="45" Margin="0,5" Content="💾 پشتیبان گیری"/>
                    <Button Height="45" Margin="0,5" Content="⚙ تنظیمات"/>

                </StackPanel>

            </DockPanel>

        </Border>

        <!-- محتوای اصلی -->


        <Grid Grid.Column="1"
      Margin="20">

            <ContentControl x:Name="MainContent"/>

        </Grid>

    </Grid>

</Window>

