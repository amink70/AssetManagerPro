<Window FlowDirection="RightToLeft" x:Class="AssetManagerPro.Views.AddAssetWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="ثبت کالا"
        Height="850"
        Width="700"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResize">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="15"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="15"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="15"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="15"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="15"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="15"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="15"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="15"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="15"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="15"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="15"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="130"/>
            <ColumnDefinition Width="15"/>
            <ColumnDefinition Width="300"/>
        </Grid.ColumnDefinitions>
        <TextBlock Grid.Row="0"
           Grid.Column="0"
           VerticalAlignment="Center"
           Text="کد اموال"/>

        <TextBox x:Name="txtAssetCode" Grid.Row="0"
         Grid.Column="2"
         Height="35"/>
        
        <TextBlock Grid.Row="2"
           Grid.Column="0"
           VerticalAlignment="Center"
           Text="نام کالا"/>

        <TextBox x:Name="txtName" Grid.Row="2"
         Grid.Column="2"
         Height="35"/>

        <TextBlock Grid.Row="4"
           Grid.Column="0"
           VerticalAlignment="Center"
           Text="برند"/>

        <ComboBox x:Name="cmbBrand"
          Grid.Row="4"
          Grid.Column="2"
          Width="300"
          Height="35"
          HorizontalAlignment="Right"
          DisplayMemberPath="Name"
          SelectedValuePath="Id"/>
        <TextBlock Grid.Row="6"
           Grid.Column="0"
           VerticalAlignment="Center"
           Text="دسته‌بندی"/>

        <ComboBox
    x:Name="cmbCategory"
    Grid.Row="6"
    Grid.Column="2"
    Width="300"
    Height="35"
    HorizontalAlignment="Right"
    DisplayMemberPath="Name"
    SelectedValuePath="Id"/>
        <TextBlock Grid.Row="8"
           Grid.Column="0"
           VerticalAlignment="Center"
           Text="محل استقرار"/>

        <ComboBox x:Name="cmbLocation"
DisplayMemberPath="Name"
SelectedValuePath="Id"
                  Grid.Row="8"
          Grid.Column="2"
          Width="300"
          Height="35"
          HorizontalAlignment="Right"/>
        <TextBlock Grid.Row="10"
           Grid.Column="0"
           VerticalAlignment="Center"
           Text="تحویل‌گیرنده"/>

        <ComboBox x:Name="cmbReceiver"
DisplayMemberPath="FullName"
SelectedValuePath="Id"
                  Grid.Row="10"
          Grid.Column="2"
          Width="300"
          Height="35"
          HorizontalAlignment="Right" 
                  />
        <TextBlock Grid.Row="12"
           Grid.Column="0"
           VerticalAlignment="Center"
           Text="وضعیت"/>

        <ComboBox x:Name="cmbStatus"
DisplayMemberPath="Name"
SelectedValuePath="Id"
                  Grid.Row="12"
          Grid.Column="2"
          Width="300"
          Height="35"
          HorizontalAlignment="Right"/>

        <TextBlock Grid.Row="14
                   "
   Grid.Column="0"
   VerticalAlignment="Center"
   Text="تامین کننده"/>

        <ComboBox x:Name="cmbSupplier"
                  DisplayMemberPath="Name"
                  SelectedValuePath="Id"
                  Grid.Row="14
                  "
  Grid.Column="2"
  Width="300"
  Height="35"
  HorizontalAlignment="Right"/>


        <TextBlock Grid.Row="16"
           Grid.Column="0"
           VerticalAlignment="Center"
           Text="قیمت"/>

        <TextBox x:Name="txtPrice" Grid.Row="16"
         Grid.Column="2"
         Width="300"
         Height="35"
         HorizontalAlignment="Right"/>
        <TextBlock Grid.Row="18"
           Grid.Column="0"
           VerticalAlignment="Center"
           Text="تاریخ خرید"/>

        <DatePicker x:Name="dpPurchaseDate" Grid.Row="18"
            Grid.Column="2"
            Width="300"
            Height="35"
            HorizontalAlignment="Right"/>
        <TextBlock Grid.Row="20"
           Grid.Column="0"
           VerticalAlignment="Top"
           Text="توضیحات"/>

        <TextBox x:Name="txtDescription" Grid.Row="20"
         Grid.Column="2"
         Width="300"
         Height="80"
         HorizontalAlignment="Right"
         AcceptsReturn="True"
         TextWrapping="Wrap"/>
        <Button
    x:Name="btnSave"
    Grid.Row="22"
    Grid.Column="2"
    Width="150"
    Height="40"
    Content="💾 ثبت کالا"
    Click="btnSave_Click"/>
    </Grid>

</Window>