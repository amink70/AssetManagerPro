<UserControl x:Class="AssetManagerPro.Views.AssetManagementView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="#F3F4F6">

    <Grid Margin="20">

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- عنوان -->
        <TextBlock Text="مدیریت اموال"
                   FontSize="24"
                   FontWeight="Bold"
                   Margin="0,0,0,20"/>

        <!-- نوار ابزار -->
        <StackPanel Grid.Row="1"
                    Orientation="Horizontal"
                    Margin="0,0,0,20">

            <Button Content="افزودن"
                    Width="120"
                    Style="{StaticResource ModernButton}"/>

            <Button Content="ویرایش"
                    Width="120"
                    Margin="10,0,0,0"
                    Style="{StaticResource ModernButton}"/>

            <Button Content="حذف"
                    Width="120"
                    Margin="10,0,0,0"
                    Style="{StaticResource ModernButton}"/>

            <TextBox Width="250"
                     Height="40"
                     Margin="30,0,0,0"/>
        </StackPanel>

        <!-- جدول -->
        
        <DataGrid Grid.Row="2"
          AutoGenerateColumns="False"
          CanUserAddRows="False"
          IsReadOnly="True"
          HeadersVisibility="Column"
          ItemsSource="{Binding Assets}" >

            <DataGrid.Columns>

                <DataGridTextColumn Header="کد اموال"
                            Binding="{Binding AssetCode}"
                            Width="120"/>

                <DataGridTextColumn Header="نام کالا"
                            Binding="{Binding Name}"
                            Width="200"/>

                <DataGridTextColumn Header="دسته‌بندی"
                            Binding="{Binding Category}"
                            Width="150"/>

                <DataGridTextColumn Header="محل استقرار"
                            Binding="{Binding Location}"
                            Width="180"/>

                <DataGridTextColumn Header="وضعیت"
                            Binding="{Binding Status}"
                            Width="120"/>

                <DataGridTextColumn Header="تاریخ ثبت"
                            Binding="{Binding PurchaseDate}"
                            Width="150"/>

            </DataGrid.Columns>

        </DataGrid>

    </Grid>

</UserControl>