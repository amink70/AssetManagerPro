<UserControl x:Class="AssetManagerPro.Views.BrandManagementView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="#F3F4F6">

    <Grid Margin="20">

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="15"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="15"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- عنوان -->

        <TextBlock Text="مدیریت برندها"
                   FontSize="26"
                   FontWeight="Bold"
                   Style="{StaticResource TitleText}"/>

        <!-- نوار بالا -->

        <Grid Grid.Row="2">

            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="250"/>
                <ColumnDefinition Width="15"/>
                <ColumnDefinition Width="170"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <TextBox x:Name="txtSearch"
                     Height="40"
                     VerticalContentAlignment="Center"/>


            <Button Grid.Column="2"
        Content="➕ افزودن برند"
        Style="{StaticResource ModernButton}"
        Click="btnAdd_Click"/>

            <Button Grid.Column="3"
        Width="120"
        Height="40"
        HorizontalAlignment="Left"
        Margin="10,0,0,0"
        Content="🗑 حذف"
        Style="{StaticResource ModernButton}"
        Click="btnDelete_Click"/>


        </Grid>

        <!-- جدول -->

        <DataGrid x:Name="dgBrands"
                  MouseDoubleClick="dgBrands_MouseDoubleClick"
                  Grid.Row="4"
                  AutoGenerateColumns="False"
                  CanUserAddRows="False"
                  Margin="0,10,0,0">

            <DataGrid.Columns>

                <DataGridTextColumn Header="شناسه"
                                    Binding="{Binding Id}"
                                    Width="90"/>

                <DataGridTextColumn Header="نام برند"
                                    Binding="{Binding Name}"
                                    Width="*"/>

                <DataGridTextColumn Header="توضیحات"
                                    Binding="{Binding Description}"
                                    Width="250"/>

            </DataGrid.Columns>

        </DataGrid>

    </Grid>

</UserControl>

