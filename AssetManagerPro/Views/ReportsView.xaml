<UserControl x:Class="AssetManagerPro.Views.ReportsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="#F3F4F6"
             FlowDirection="RightToLeft">

    <Grid Margin="20">

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- عنوان -->
        <TextBlock Text="گزارش‌ها"
                   FontSize="26"
                   FontWeight="Bold"
                   Margin="0,0,0,20"/>

        <!-- نوار ابزار -->
        <Border Grid.Row="1"
                Background="White"
                CornerRadius="10"
                Padding="15"
                Margin="0,0,0,20">

            <WrapPanel>

                <Button Content="همه اموال"
        Width="140"
        Height="40"
        Margin="5"
        Click="btnAllAssets_Click"/>


                <Button Content="اموال سالم"
        Width="140"
        Height="40"
        Margin="5"
        Click="btnHealthyAssets_Click"/>

                <Button Content="اموال خراب"
                        Width="140"
                        Height="40"
                        Margin="5"/>

                <Button Content="در تعمیر"
                        Width="140"
                        Height="40"
                        Margin="5"/>

                <Button Content="گردش اموال"
                        Width="140"
                        Height="40"
                        Margin="5"/>

                <Button Content="خروجی Excel"
                        Width="140"
                        Height="40"
                        Margin="20,5,5,5"/>

                <Button Content="خروجی PDF"
                        Width="140"
                        Height="40"
                        Margin="5"/>

                <Button Content="چاپ"
                        Width="140"
                        Height="40"
                        Margin="5"/>

            </WrapPanel>

        </Border>
        <ScrollViewer HorizontalScrollBarVisibility="Auto"
              VerticalScrollBarVisibility="Disabled">

            <!-- جدول گزارش -->
        <DataGrid Grid.Row="2"
          x:Name="dgReports"
          Style="{StaticResource ModernDataGridStyle}"
          AutoGenerateColumns="False"
          CanUserAddRows="False"
          IsReadOnly="True"
          HeadersVisibility="Column"
          ScrollViewer.HorizontalScrollBarVisibility="Auto"
          ScrollViewer.VerticalScrollBarVisibility="Auto">

            <DataGrid.Columns>

                <DataGridTextColumn Header="کد اموال"
                        Binding="{Binding AssetCode}"
                        Width="110"/>

                <DataGridTextColumn Header="نام کالا"
                        Binding="{Binding Name}"
                        Width="170"/>

                <DataGridTextColumn Header="برند"
                        Binding="{Binding Brand}"
                        Width="120"/>

                <DataGridTextColumn Header="دسته‌بندی"
                        Binding="{Binding Category}"
                        Width="140"/>

                <DataGridTextColumn Header="محل استقرار"
                        Binding="{Binding Location}"
                        Width="150"/>

                <DataGridTextColumn Header="گیرنده"
                        Binding="{Binding Receiver}"
                        Width="150"/>

                <DataGridTextColumn Header="وضعیت"
                        Binding="{Binding Status}"
                        Width="110"/>

                <DataGridTextColumn Header="قیمت"
                        Binding="{Binding Price,StringFormat={}{0:N0}}"
                        Width="120"/>

                <DataGridTextColumn Header="تاریخ خرید"
                        Binding="{Binding PurchaseDate}"
                        Width="140"/>

            </DataGrid.Columns>

        </DataGrid>
        </ScrollViewer>

    </Grid>

</UserControl>