<UserControl x:Class="AssetManagerPro.Views.TransactionManagementView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Grid Margin="20">

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <DockPanel Margin="0,0,0,15">

            <TextBlock Text="مدیریت گردش اموال"
                       FontSize="24"
                       FontWeight="Bold"
                       VerticalAlignment="Center"/>

            <Button Content="➕ ثبت گردش"
                    Click="btnAddTransaction_Click"
                    Width="150"
                    Height="40"
                    HorizontalAlignment="Left"
                    DockPanel.Dock="Left"
                    Margin="10,0,0,0"/>

        </DockPanel>

        <DataGrid x:Name="dgTransactions"
                  Grid.Row="1"
                  AutoGenerateColumns="False"
                  IsReadOnly="True">

            <DataGrid.Columns>

                <DataGridTextColumn Header="شناسه"
                                    Binding="{Binding Id}"
                                    Width="70"/>

                <DataGridTextColumn Header="دارایی"
                                    Binding="{Binding AssetName}"
                                    Width="90"/>

                <DataGridTextColumn Header="گیرنده"
                                    Binding="{Binding ReceiverName}"
                                    Width="100"/>

                <DataGridTextColumn Header="مکان"
                                    Binding="{Binding LocationName}"
                                    Width="90"/>

                <DataGridTextColumn Header="نوع گردش"
                                    Binding="{Binding TransactionType}"
                                    Width="120"/>

                <DataGridTextColumn Header="تاریخ"
                                    Binding="{Binding TransactionDate}"
                                    Width="180"/>

                <DataGridTextColumn Header="توضیحات"
                                    Binding="{Binding Description}"
                                    Width="*"/>

            </DataGrid.Columns>

        </DataGrid>

    </Grid>

</UserControl>

