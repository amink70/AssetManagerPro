<UserControl x:Class="AssetManagerPro.Views.Dashboard.StatisticCards"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    
        <UniformGrid 
             Columns="4"
             Margin="0">

            <!-- کارت اول -->

            <Border Style="{StaticResource CardStyle}"
            Margin="5">

                <Grid>

                    <Grid.RowDefinitions>

                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>

                    </Grid.RowDefinitions>



                    <TextBlock Grid.Row="1"
                       Text="کل اموال"
                       FontWeight="SemiBold"
                       FontSize="15"
                       HorizontalAlignment="Center"
                       Margin="0,5"/>

                    <TextBlock Grid.Row="2"
                       Text="{Binding TotalAssets}"
                       FontSize="30"
                       FontWeight="Bold"
                       Foreground="{StaticResource PrimaryBrush}"
                       HorizontalAlignment="Center"
                       Margin="0,5,0,10"/>

                </Grid>

            </Border>

            <!-- کارت دوم -->

            <Border Style="{StaticResource CardStyle}"
            Margin="5">

                <Grid>

                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBlock Text="✅"
                       FontSize="38"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center"/>

                    <TextBlock Grid.Row="1"
                       Text="اموال سالم"
                       FontWeight="SemiBold"
                       HorizontalAlignment="Center"
                       Margin="0,5"/>

                    <TextBlock Grid.Row="2"
                       Text="{Binding HealthyAssets}"
                       FontSize="30"
                       FontWeight="Bold"
                       Foreground="{StaticResource SuccessBrush}"
                       HorizontalAlignment="Center"
                       Margin="0,5,0,10"/>

                </Grid>

            </Border>
            <!-- کارت سوم -->

            <Border Style="{StaticResource CardStyle}"
            Margin="5">

                <Grid>

                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBlock Text="🔧"
                       FontSize="38"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center"/>

                    <TextBlock Grid.Row="1"
                       Text="در تعمیر"
                       FontWeight="SemiBold"
                       HorizontalAlignment="Center"
                       Margin="0,5"/>

                    <TextBlock Grid.Row="2"
                       Text="{Binding RepairAssets}"
                       FontSize="30"
                       FontWeight="Bold"
                       Foreground="{StaticResource WarningBrush}"
                       HorizontalAlignment="Center"
                       Margin="0,5,0,10"/>

                </Grid>

            </Border>

            <!-- کارت چهارم -->

            <Border Style="{StaticResource CardStyle}"
            Margin="5">

                <Grid>

                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBlock Text="❌"
                       FontSize="38"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center"/>

                    <TextBlock Grid.Row="1"
                       Text="اموال خراب"
                       FontWeight="SemiBold"
                       HorizontalAlignment="Center"
                       Margin="0,5"/>

                    <TextBlock Grid.Row="2"
                       Text="{Binding BrokenAssets}"
                       FontSize="30"
                       FontWeight="Bold"
                       Foreground="{StaticResource DangerBrush}"
                       HorizontalAlignment="Center"
                       Margin="0,5,0,10"/>

                </Grid>

            </Border>

        </UniformGrid>
    
</UserControl>