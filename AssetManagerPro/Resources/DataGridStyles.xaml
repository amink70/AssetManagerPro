<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Style x:Key="ModernDataGridStyle"
           TargetType="DataGrid">

        <Setter Property="Background" Value="White"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="GridLinesVisibility" Value="Horizontal"/>
        <Setter Property="HeadersVisibility" Value="Column"/>
        <Setter Property="RowHeight" Value="42"/>
        <Setter Property="ColumnHeaderHeight" Value="45"/>
        <Setter Property="CanUserResizeColumns" Value="True"/>
        <Setter Property="CanUserSortColumns" Value="True"/>
        <Setter Property="SelectionMode" Value="Single"/>
        <Setter Property="SelectionUnit" Value="FullRow"/>
        <Setter Property="AlternatingRowBackground" Value="#F8FAFC"/>
        <Setter Property="RowBackground" Value="White"/>
        <Setter Property="HorizontalGridLinesBrush" Value="#E5E7EB"/>
        <Setter Property="VerticalGridLinesBrush" Value="#E5E7EB"/>

    </Style>

</ResourceDictionary>